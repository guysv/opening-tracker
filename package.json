{
  "name": "opening-tracker",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run serve.dev.ts",
    "dev:hot": "bun run --hot serve.dev.ts",
    "build": "bun run build.ts",
    "preview": "bun run build.ts && bunx serve dist",
    "check": "tsc --noEmit",
    "cf:login": "wrangler login",
    "cf:pages:deploy": "bun run build && wrangler pages deploy dist"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^5.9.3",
    "wrangler": "^4.77.0"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8",
    "bitboard-chess": "^0.4.0",
    "pgn-parser": "^2.2.1",
    "preact": "^10.29.0",
    "preact-iso": "^2.11.1",
    "stockfish": "^18.0.5"
  }
}
